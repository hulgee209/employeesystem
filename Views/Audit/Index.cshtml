@model IEnumerable<EmployeeSystem.Models.AuditLog>

@{
    ViewData["Title"] = "Аудитын бүртгэл";
    var totalPages = ViewBag.TotalPages as int? ?? 1;
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
}

<div class="container mt-4">
    <h2>Аудитын бүртгэл</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-header">
            <h5>Бүртгэл шүүх</h5>
        </div>
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label for="tableName" class="form-label">Хүснэгт</label>
                    <select id="tableName" name="tableName" class="form-select">
                        <option value="">Бүх хүснэгт</option>
                        @foreach (var table in ViewBag.TableNames)
                        {
                            <option value="@table" selected="@(ViewBag.TableName == table)">@table</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="action" class="form-label">Үйлдэл</label>
                    <select id="action" name="action" class="form-select">
                        <option value="">Бүх үйлдэл</option>
                        @foreach (var act in ViewBag.Actions)
                        {
                            <option value="@act" selected="@(ViewBag.Action == act)">@act</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label for="startDate" class="form-label">Эхлэх огноо</label>
                    <input type="date" id="startDate" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-2">
                    <label for="endDate" class="form-label">Дуусах огноо</label>
                    <input type="date" id="endDate" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary">Шүүх</button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary">Цэвэрлэх</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Огноо</th>
                    <th>Хэрэглэгч</th>
                    <th>Үйлдэл</th>
                    <th>Хүснэгт</th>
                    <th>Бичлэгийн дугаар</th>
                    <th>IP хаяг</th>
                    <th>Харах</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@log.UserName</td>
                            <td>
                                @switch (log.Action)
                                {
                                    case "CREATE":
                                        <span class="badge bg-success">Үүсгэсэн</span>
                                        break;
                                    case "UPDATE":
                                        <span class="badge bg-info">Шинэчилсэн</span>
                                        break;
                                    case "DELETE":
                                        <span class="badge bg-danger">Устгасан</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@log.Action</span>
                                        break;
                                }
                            </td>
                            <td>@log.TableName</td>
                            <td>@log.RecordId</td>
                            <td><small>@log.IpAddress</small></td>
                            <td>
                                <a href="@Url.Action("Details", new { id = log.AuditLogId })" class="btn btn-sm btn-info">Дэлгэрэнгүй</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted">Аудитын бүртгэл олдсонгүй</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Хуудас">
            <ul class="pagination justify-content-center">
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = 1, tableName = ViewBag.TableName, action = ViewBag.Action })">Эхний</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, tableName = ViewBag.TableName, action = ViewBag.Action })">Өмнөх</a>
                    </li>
                }

                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, tableName = ViewBag.TableName, action = ViewBag.Action })">@i</a>
                    </li>
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, tableName = ViewBag.TableName, action = ViewBag.Action })">Дараах</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = totalPages, tableName = ViewBag.TableName, action = ViewBag.Action })">Сүүлийн</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="card mt-4 border-warning">
        <div class="card-header bg-warning">
            <h5 class="mb-0">Засвар үйлчилгээ - хуучин бүртгэл устгах</h5>
        </div>
        <div class="card-body">
            <form method="post" action="@Url.Action("DeleteOlderThan")" style="display: inline;">
                @Html.AntiForgeryToken()
                <p>Заасан өдрөөс хуучин аудитын бүртгэлийг бүр мөсөн устгана. Хамгийн багадаа 7 өдөр.</p>
                <div class="row">
                    <div class="col-md-3">
                        <input type="number" name="daysOld" min="7" value="90" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <button type="submit" class="btn btn-warning" onclick="return confirm('Устгахдаа итгэлтэй байна уу? Энэ үйлдлийг буцаах боломжгүй.');">Бүртгэл устгах</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .badge {
        font-size: 0.85rem;
    }

    .table tbody tr:hover {
        background-color: #f5f5f5;
    }
</style>
