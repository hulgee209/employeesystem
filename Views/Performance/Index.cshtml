@model EmployeeSystem.Models.PerformanceIndexViewModel

@{
    ViewData["Title"] = "Гүйцэтгэл";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Гүйцэтгэл</h2>
        <p class="text-muted mb-0">Гүйцэтгэлийн үнэлгээ, онооны харьцуулалт болон шинжилгээ.</p>
    </div>
</div>

<form method="get" class="card grid-card mb-4">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Ажилтан</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Ажилтнаар хайх" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Хэлтэс</label>
                <select name="departmentId" class="form-select" asp-items="Model.Departments">
                    <option value="">Бүх хэлтэс</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Үнэлгээний огноо</label>
                <input name="date" value="@Model.Date?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-primary" type="submit">Шүүх</button>
            </div>
        </div>
    </div>
</form>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <span class="metric-label">Дундаж гүйцэтгэлийн оноо</span>
                <strong>@Model.AveragePerformanceScore.ToString("N2")</strong>
                <small>Шүүсэн бүртгэлүүд</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <span class="metric-label">Шилдэг ажилтан</span>
                <strong>@Model.TopEmployee</strong>
                <small>Дундаж оноогоор</small>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card metric-card">
            <div class="card-body">
                <span class="metric-label">Хамгийн өндөр оноотой хэлтэс</span>
                <strong>@Model.HighestDepartmentScore</strong>
                <small>Дундаж оноогоор</small>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card graph-card h-100">
            <div class="card-body">
                <div class="graph-title">
                    <span>Хэлтсүүдийн гүйцэтгэлийн харьцуулалт</span>
                    <small>Топ 10</small>
                </div>
                <canvas id="departmentPerformanceChart" height="260"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card graph-card h-100">
            <div class="card-body">
                <div class="graph-title">
                    <span>Ажилтны онооны тархалт</span>
                    <small>Онооны бүлэг</small>
                </div>
                <canvas id="scoreDistributionChart" height="260"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="card grid-card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Огноо</th>
                        <th>Ажилтан</th>
                        <th>Хэлтэс</th>
                        <th>Оноо</th>
                        <th>Үнэлэгч</th>
                        <th>Тайлбар</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Records)
                {
                    <tr>
                        <td>@(item.ReviewDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                        <td>@item.EmployeeName</td>
                        <td>@item.DepartmentName</td>
                        <td class="fw-bold">@(item.Score?.ToString("N2") ?? "-")</td>
                        <td>@(item.Reviewer ?? "-")</td>
                        <td>@(item.Comments ?? "-")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        fetch('/Performance/DepartmentComparison')
            .then(response => response.json())
            .then(data => {
                new Chart(document.getElementById('departmentPerformanceChart'), {
                    type: 'bar',
                    data: {
                        labels: data.map(item => item.label),
                        datasets: [{
                            label: 'Дундаж оноо',
                            data: data.map(item => item.score),
                            backgroundColor: '#7c3aed'
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            });

        fetch('/Performance/ScoreDistribution')
            .then(response => response.json())
            .then(data => {
                new Chart(document.getElementById('scoreDistributionChart'), {
                    type: 'doughnut',
                    data: {
                        labels: data.map(item => item.label),
                        datasets: [{
                            data: data.map(item => item.count),
                            backgroundColor: ['#dc2626', '#ea580c', '#f59e0b', '#2563eb', '#059669']
                        }]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            });
    </script>
}
