@{
    ViewData["Title"] = "AI HR Assistant";
}

<style>
    .chat-container {
        display: flex;
        height: calc(100vh - 100px);
        gap: 14px;
        padding: 14px;
        background: #f3f6fb;
    }

    .sessions-sidebar {
        width: 280px;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 12px 28px rgba(15, 23, 42, 0.06);
    }

    .sidebar-header {
        padding: 16px;
        border-bottom: 1px solid #e5e7eb;
    }

    .sidebar-header h5 {
        margin: 0 0 12px;
        font-size: 15px;
        font-weight: 600;
    }

    #newChatBtn {
        width: 100%;
        font-size: 13px;
    }

    #sessionsList {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
    }

    .list-group-item {
        border: none;
        border-radius: 8px;
        margin-bottom: 6px;
        padding: 8px;
        font-size: 13px;
    }

    .chat-session-item {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
        align-items: center;
        border-left: 3px solid transparent;
        background: #ffffff;
    }

    .chat-session-item.pinned {
        border-left-color: #f59e0b;
        background: #fffbeb;
    }

    .chat-session-item.active {
        background: #eaf2ff;
        color: #0f172a;
    }

    .session-open-btn {
        display: grid;
        gap: 3px;
        min-width: 0;
        border: 0;
        padding: 0;
        background: transparent;
        color: inherit;
        text-align: left;
    }

    .session-title {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 600;
    }

    .session-date {
        color: #64748b;
        font-size: 12px;
    }

    .session-actions {
        display: inline-flex;
        gap: 4px;
        opacity: 0.78;
    }

    .chat-session-item:hover .session-actions,
    .chat-session-item.active .session-actions {
        opacity: 1;
    }

    .session-actions .btn {
        width: 28px;
        height: 28px;
        padding: 0;
        line-height: 1;
    }

    .list-group-item.active {
        background-color: #2563eb;
        color: white;
    }

    .list-group-item:hover {
        background-color: #f3f4f6;
    }

    .list-group-item.active:hover {
        background-color: #1d4ed8;
    }

    .chat-session-item.active,
    .chat-session-item.active:hover {
        background: #eaf2ff;
        color: #0f172a;
    }

    .chat-session-item.pinned.active,
    .chat-session-item.pinned.active:hover {
        background: #fff7d6;
    }

    .chat-shell {
        flex: 1;
        display: flex;
        flex-direction: column;
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
        margin: 0;
    }

    .chat-header {
        padding: 18px 22px;
        background: linear-gradient(135deg, #1e3a8a, #2f5fb8);
        color: #ffffff;
    }

    .chat-header h2 {
        font-size: 22px;
        margin: 0;
        font-weight: 700;
    }

    .chat-header p {
        margin: 4px 0 0;
        color: #d1d5db;
        font-size: 14px;
    }

    .chat-history {
        flex: 1;
        overflow-y: auto;
        padding: 24px;
        background: #f7faff;
    }

    .message {
        display: flex;
        margin-bottom: 16px;
        flex-direction: column;
    }

    .message-user {
        align-items: flex-end;
    }

    .message-assistant,
    .message-error {
        align-items: flex-start;
    }

    .message-header {
        display: flex;
        gap: 8px;
        font-size: 12px;
        margin-bottom: 4px;
        color: #6b7280;
    }

    .message-time {
        color: #9ca3af;
        font-size: 11px;
    }

    .message-content {
        max-width: min(720px, 82%);
        padding: 13px 15px;
        border-radius: 8px;
        line-height: 1.55;
        white-space: pre-wrap;
        word-break: break-word;
    }

    .message-user .message-content {
        background: #2563eb;
        color: #ffffff;
    }

    .message-assistant .message-content {
        background: #ffffff;
        color: #111827;
        border: 1px solid #e5e7eb;
    }

    .message-error .message-content {
        background: #fee2e2;
        color: #991b1b;
    }

    .sql-display {
        margin-top: 8px;
        padding: 8px;
        background: #f3f4f6;
        border-left: 3px solid #9ca3af;
        font-family: 'Courier New', monospace;
        word-break: break-all;
    }

    .execution-time {
        margin-top: 4px;
        color: #6b7280;
        font-size: 11px;
    }

    .chat-input-area {
        padding: 16px;
        border-top: 1px solid #e5e7eb;
        background: #ffffff;
    }

    .btn-group-input {
        display: flex;
        gap: 8px;
    }

    #questionInput {
        flex: 1;
        min-height: 44px;
        max-height: 140px;
        font-size: 14px;
    }

    #sendBtn {
        padding: 0 20px;
        min-width: 100px;
    }

    .loading-indicator {
        text-align: center;
        color: #9ca3af;
        padding: 32px;
    }

    @@media (max-width: 768px) {
        .sessions-sidebar {
            width: 200px;
        }

        .message-content {
            max-width: 90%;
        }
    }

    @@media (max-width: 576px) {
        .chat-container {
            flex-direction: column;
        }

        .sessions-sidebar {
            width: 100%;
            height: 150px;
            border-right: none;
            border-bottom: 1px solid #e5e7eb;
        }

        #sessionsList {
            flex-direction: row;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .chat-shell {
            margin: 0;
            border-radius: 0;
        }
    }
</style>

<div class="chat-container">
    <!-- Sessions Sidebar -->
    <div class="sessions-sidebar">
        <div class="sidebar-header">
            <h5>Conversation History</h5>
            <button id="newChatBtn" type="button" class="btn btn-sm btn-primary">
                + New Chat
            </button>
        </div>
        <div id="sessionsList" class="list-group"></div>
    </div>

    <!-- Main Chat Area -->
    <div class="chat-shell">
        <div class="chat-header">
            <h2>AI HR Assistant</h2>
            <p>Байгууллагын ажилтан, хэлтэс, албан тушаалын өгөгдөл дээр үндэслэн HR асуултад хариулна.</p>
        </div>

        <div id="messagesContainer" class="chat-history">
            <div class="loading-indicator">
                Сайн байна уу. HR мэдээлэлтэй холбоотой асуултаа бичнэ үү.
            </div>
        </div>

        <div class="chat-input-area">
            <div class="btn-group-input">
                <textarea id="questionInput"
                          class="form-control"
                          rows="1"
                          placeholder="Жишээ: IT хэлтэст хэдэн ажилтан байна вэ?"
                          autocomplete="off"></textarea>
                <button id="sendBtn" type="button" class="btn btn-primary">
                    Илгээх
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chat.js"></script>
}
